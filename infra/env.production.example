# Timesheet App — VM101 (Option B: backend on VM106)

# Public Timesheet URL (this container)
TIMESHEET_PORT=5180

# SupaDupaBase backend (VM106) — browser calls these directly
SDB_PUBLIC_URL=https://supadupabase.whitelynx.co.nz
# SDB_AUTH_URL=   # defaults to SDB_PUBLIC_URL
# SDB_DATA_URL=
# SDB_MAIL_URL=

# Disable API proxy — PWA talks to VM106 over HTTPS (not same-origin)
SDB_PROXY=0

# Web Push (copy VAPID_PUBLIC_KEY from VM106 supadupabase .env)
VAPID_PUBLIC_KEY=
