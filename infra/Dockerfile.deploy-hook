FROM node:22-alpine
RUN apk add --no-cache docker-cli-compose git bash \
  && git config --global --add safe.directory /repo
WORKDIR /repo
COPY infra/deploy-hook/server.mjs /app/server.mjs
ENV NODE_ENV=production
ENV REPO_ROOT=/repo
ENV DEPLOY_SCRIPT=infra/deploy-quick.sh
CMD ["node", "/app/server.mjs"]
